# Copy to backend/.env and fill in real values. Never commit .env.
DATABASE_URL=postgresql://user:password@host:5432/marketpulse
OPENROUTER_API_KEY=sk-or-...
COINGECKO_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
APP_ENV=development
# Max fresh LLM scorings per UTC day (~$0.008 each). Over this, requests serve
# the last stored score as stale. Raise/lower to set your daily cost ceiling.
SCORING_DAILY_CAP=300
# Comma-separated browser origins allowed to call the API (CORS). In prod set
# this to your deployed frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
